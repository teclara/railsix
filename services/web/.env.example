API_BASE_URL=http://localhost:8082
SSE_PUSH_URL=http://localhost:8085
# Optional: shared rate limiting for the web service.
# REDIS_ADDR=localhost:6379
# REDIS_PASSWORD=
# When deploying behind a trusted reverse proxy, configure adapter-node client IP handling.
# ADDRESS_HEADER=x-forwarded-for
# XFF_DEPTH=1
PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here
VITE_DEV_PORT=5173
# Set to 1 when exposing dev over Tunnelmole or another proxy that doesn't forward Vite HMR websockets.
VITE_DISABLE_HMR=0
# Optional: if your proxy does support websocket forwarding, point this at the public HMR origin.
# VITE_PUBLIC_HMR_URL=https://your-public-host.example.com
# VITE_PUBLIC_HMR_PATH=/__vite_hmr
